# === Opta API ===
# Auth method: "url_key" (requer IP whitelisting) ou "oauth"
OPTA_AUTH_METHOD=url_key
OPTA_OUTLET_AUTH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
OPTA_BASE_URL=https://api.performfeeds.com/soccerdata

# OAuth credentials (só se OPTA_AUTH_METHOD=oauth)
OPTA_OAUTH_TOKEN_ENDPOINT=
OPTA_OAUTH_CLIENT_ID=
OPTA_OAUTH_CLIENT_SECRET=

# Mock mode — usar enquanto API real não estiver liberada
OPTA_USE_MOCK=true
OPTA_REQUEST_TIMEOUT=3

# === Google Cloud ===
GCP_PROJECT_ID=your-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# === LLM (selecao de stats) ===
# Provider: "groq" (gratuito), "gemini", ou "fallback" (sem LLM)
LLM_PROVIDER=groq
LLM_TIMEOUT=5

# Groq (gratuito — https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (alternativa)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# === Google Sheets ===
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
SHEETS_WORKSHEET_NAME=Sheet1

# === Firestore ===
FIRESTORE_COLLECTION=matches

# === Recognition Service ===
RECOGNITION_URL=http://localhost:8081
RECOGNITION_THRESHOLD=0.6
PLAYER_DB_MODE=local
LOCAL_DB_PATH=local_players.json

# === Data Fetcher Service ===
DATA_FETCHER_URL=http://localhost:8082

# === Capture ===
CAPTURE_SOURCE=ndi
CAPTURE_NDI_NAME=VMIX
CAPTURE_RTMP_URL=rtmp://localhost/live/stream
CAPTURE_FPS=2
CAPTURE_FACE_CONFIDENCE=0.9
CAPTURE_DEBOUNCE_SECONDS=30

# === Match Context ===
MATCH_ID=
COMPETITION_ID=
SEASON_ID=
